// ── helpers для примеров заголовков ──
#let eh1(t) = {
  box(width: 1.25cm)
  text(font: "Arial", size: 14pt, hyphenate: false)[#t]
}
#let eh2(t) = {
  box(width: 1.25cm)
  text(font: "Arial", size: 13pt, hyphenate: false)[#t]
}
#let eh3(t) = {
  box(width: 1.25cm)
  text(font: "Times New Roman", size: 12pt, weight: "bold", hyphenate: false)[#t]
}
#let etx(t) = {
  box(width: 1.25cm)
  t
}
#let ecap(t) = text(style: "italic", size: 9pt, fill: mid)[#t]

// ── helpers для примера «Содержание» ──
// num — строка номера («1», «1.1», «1.1.1»). Отступ строки = сумма ширин
// префиксов всех предков («1 », «1.1 » …), поэтому номер каждого уровня встаёт
// ровно под первой буквой заголовка родителя. Между номером и заголовком —
// один пробел; перенос строки (hanging-indent) встаёт под первую букву заголовка.
#let tn(num, title, pg) = (
  context {
    let parts = num.split(".")
    let lead = 0pt
    for i in range(parts.len() - 1) {
      lead += measure([#parts.slice(0, i + 1).join(".")#h(0.25em)]).width
    }
    let pfx = [#h(lead)#num#h(0.25em)]
    let w = measure(pfx).width
    par(hanging-indent: w)[#box(width: w, pfx)#title #box(width: 1fr, repeat[.])]
  },
  [#pg],
)
// Строка без номера (Введение, Заключение, Приложение …) — на уровне разделов
#let tz(title, pg) = (
  par(hanging-indent: 0pt)[#title #box(width: 1fr, repeat[.])],
  [#pg],
)

#let HX(cap, body) = E({
  set par(first-line-indent: 0pt, leading: 6pt, spacing: 0pt)
  set text(size: 12pt)
  ecap(cap)
  v(10pt)
  body
})

#HX("1) Первый уровень + текст")[
  #eh1[1 Анализ предметной области]
  #v(12pt)
  #etx[Текст раздела начинается с абзацного отступа и идёт в полуторном интервале.]
]

#HX("2) Первый + второй уровень + текст")[
