  ecap(t)
  v(12pt)
}

// ── helpers для примера «Содержание» ──
// num — строка номера («1», «1.1», «1.1.1»). Отступ строки = сумма ширин
// префиксов всех предков («1 », «1.1 » …), поэтому номер каждого уровня встаёт
// ровно под первой буквой заголовка родителя. Между номером и заголовком —
// один пробел; перенос строки (hanging-indent) встаёт под первую букву заголовка.
#let tn(num, title, pg) = context {
  let parts = num.split(".")
  let lead = 1.25cm * (parts.len() - 1)
  let pfx = [#h(lead)#num#h(0.25em)]
  let w = measure(pfx).width
  layout(size => {
    let line_h = measure(block(width: size.width - w)[x]).height
    let title_h = measure(block(width: size.width - w, title)).height
    let dots = [#box(width: 1fr, repeat[.]) #pg]
    if title_h > line_h {
      par(hanging-indent: w)[#box(width: w, pfx)#title#linebreak()#h(w)#dots]
    } else {
      par(hanging-indent: w)[#box(width: w, pfx)#title #dots]
    }
  })
}
// Строка без номера (Введение, Заключение, Приложение …) — от начала номеров разделов
#let tz(title, pg) = par[#title #box(width: 1fr, repeat[.]) #pg]

