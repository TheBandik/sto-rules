// СК-СТО-ТР-04-1.005-2015 – краткий справочник правил оформления

#set page(paper: "a4", margin: 2cm)
#set text(font: "Times New Roman", size: 12pt, lang: "ru", hyphenate: false)
#set par(justify: true, leading: 0.5em, spacing: 0.6em, first-line-indent: 0pt)
#show " – ": [~– ]
#show table.cell.where(y: 0): set text(hyphenate: false)  // без переноса в заголовках столбцов
#import "@preview/fletcher:0.5.8" as fletcher: diagram, edge, node
#import fletcher.shapes: diamond, hexagon, parallelogram, pill

// ── Палитра (монохром) ───────────────────────────────────────────────────
#let dark = rgb("#1a1a1a")
#let mid = rgb("#555555")
#let lite = rgb("#f2f2f2")
#let brd = rgb("#cccccc")
#let brd-dk = rgb("#888888")

// Процедура (предопределенный процесс): прямоугольник с линиями слева и справа
#let procedure-shape(node, extrude) = {
  let draw = fletcher.cetz.draw
  let (w, h) = node.size
  let (x, y) = (w / 2 + extrude, h / 2 + extrude)
  let d = calc.min(w, h) * 0.18
  draw.group({
    draw.rect((-x, -y), (x, y))
    draw.line((-x + d, -y), (-x + d, y))
    draw.line((x - d, -y), (x - d, y))
  })
}

// Комментарий по ISO/ГОСТ: открытая скобка слева от поясняющего текста
#let comment-shape(node, extrude) = {
  let draw = fletcher.cetz.draw
  let (w, h) = node.size
  let (x, y) = (w / 2 + extrude, h / 2 + extrude)
  let d = calc.min(w, h) * 0.22
  draw.group({
    draw.line((-x, -y), (-x, y))
    draw.line((-x, -y), (-x + d, -y))
    draw.line((-x, y), (-x + d, y))
  })
}

// ── Счетчики ─────────────────────────────────────────────────────────────
#let sec-count = counter("sto-section")
#let rule-count = counter("sto-rule")
#let example-count = counter("sto-example")
#let param-count = counter("sto-param")
#let rule-param-state = state("sto-rule-param", 0)

// Легенда (бейджи) для правил (параметров) и примеров
#let two(n) = if n < 10 { "0" + str(n) } else { str(n) }
#let item-code(prefix, item-counter) = context {
  let sec = sec-count.get().at(0)
  let item = item-counter.get().at(0)
  prefix + " " + two(sec) + "-" + two(item)
}
#let side-tag-width = 0.9cm
#let side-tag-offset = 0.2cm
#let side-tag(code, fill: dark) = rect(width: side-tag-width, height: 0.36cm, fill: fill, radius: 1pt)[
  #set align(center + horizon)
  #text(font: "Arial", size: 6.5pt, weight: "bold", fill: white)[#code]
]
#let margin-tag(code, dx: side-tag-offset, fill: dark) = box(width: 0pt)[
  #place(left + top, dx: dx)[#side-tag(code, fill: fill)]
]

// ── Межстрочный интервал «как в Word» ──────────────────────────────────────
// В Word множитель применяется к высоте строки шрифта (для TNR ≈ 1.15 × кегль),
// а не к голому кеглю. В Typst leading — это зазор между строками; строчный бокс
// здесь равен 0.6625em. Отсюда: leading = (1.15·m − 0.6625)·1em.
//   wlead(1)   — одинарный  (advance ≈ 1.15em)
//   wlead(1.5) — полуторный (advance ≈ 1.725em)
//   wlead(2)   — двойной    (advance ≈ 2.3em)
// Значение в em → автоматически масштабируется с размером шрифта.
#let wlead(m) = (1.15 * m - 0.6625) * 1em
// Добавка к row-gutter, превращающая одинарный в полуторный между строками таблицы
#let wgap = (1.725 - 1.15) * 1em

// ── Компоненты ───────────────────────────────────────────────────────────

// Заголовок раздела
#let S(t) = {
  sec-count.step()
  rule-count.update(0)
  example-count.update(0)
  param-count.update(0)
  pagebreak(weak: true)
  text(font: "Arial", size: 14pt, weight: "bold")[#context sec-count.display("1.") #t]
  v(0.1em)
  line(length: 100%, stroke: 1pt + dark)
  v(0.3em)
}

// Блок параметров
#let R(body) = {
  rule-count.step()
  rule-param-state.update(0)
  block(
    width: 100%,
    stroke: (left: 2.5pt + dark, rest: 0.4pt + brd),
    inset: (left: 10pt, right: 8pt, y: 7pt),
    body,
  )
  v(0.25em)
}

// Строка параметра внутри R
#let P(param, val) = {
  context {
    if rule-param-state.get() > 0 {
      block(width: 100%, height: 0pt, above: 0pt, below: 6pt, breakable: false)[
        #line(length: 100%, stroke: (paint: brd-dk, thickness: 0.6pt, dash: (array: (0.25pt, 0.9pt), phase: 0pt)))
      ]
    }
  }
  // Если нет второго тела - значит это не параметр, а подраздел
  let is-subhead = val == []
  if not is-subhead {
    param-count.step()
  }
  context grid(
    columns: (4cm, 1fr, 0pt),
    column-gutter: (0.5em, 0pt),
    {
      rule-param-state.update(n => n + 1)
      text(weight: "bold", size: 13pt)[#param]
    },
    {
      val
    },
    if not is-subhead { margin-tag(item-code("P", param-count), dx: side-tag-offset + 8pt) },
  )
  v(0.5em)
}

// Пример
#let E(body) = {
  example-count.step()
  v(0.2em)
  block(breakable: false)[
    #grid(
      columns: (1fr, 0pt),
      column-gutter: 0pt,
      text(size: 11pt, style: "italic")[Пример], margin-tag(item-code("E", example-count), fill: brd-dk),
    )
    #v(0.1em)
    #block(
      width: 100%,
      stroke: 0.5pt + brd-dk,
      radius: 2pt,
      inset: (x: 12pt, y: 10pt),
      text(hyphenate: true, body), // в примерах автоперенос оставляем (правило СТО)
    )
  ]
  v(0.35em)
}

// Важно
#let W(body) = {
  param-count.step()
  block(
    width: 100%,
    stroke: (left: 2.5pt + dark, rest: 0.4pt + brd),
    inset: (left: 10pt, right: 8pt, y: 7pt),
  )[
    #grid(
      columns: (1fr, 0pt),
      column-gutter: 0pt,
      [#text(size: 12pt, weight: "bold")[!#h(0.4em)]#body],
      margin-tag(item-code("P", param-count), dx: side-tag-offset + 8pt),
    )
  ]
  v(0.25em)
}

