// ═══════════════════════════════════════════════════════════════════════════
// СТРАНИЦЫ 3+ – ПРАВИЛА
// ═══════════════════════════════════════════════════════════════════════════

#pagebreak()
#set page(numbering: "1")
#counter(page).update(3)

// ─────────────────────────────────────────────────────────────────────────
#S[Страница и поля]

#R[
  #P[Формат][Лист *А4* (210×297 мм), печать с *одной стороны*, цвет шрифта *чёрный*]
  #P[Поля][Левое – *3 см* (30 мм), правое – *1 см* (10 мм), верхнее и нижнее – по *2 см* (20 мм)]
  #P[Нумерация страниц][Арабские цифры, *сквозная* по всему документу, *включая приложения*. Номер – в правом верхнем углу, на уровне верхнего поля, *выровнен по правому краю текстовой области*. На странице содержания номер *не ставится*. *Без точек и чёрточек*, Times New Roman *12 пт*]
  #P[Титульный лист][*Входит* в нумерацию, но номер на нём *не ставится*]
  #P[Задание, Аннотация (Реферат)][Номер *не присваивается*, в «Содержание» *не входят*. Размещаются сразу после титульного листа]
]

#E[
  #set text(size: 9pt)
  #set par(first-line-indent: 0pt, leading: 0.5em)
  // Размерные линии полей
  #let dim-stroke = (paint: mid, thickness: 0.35pt, dash: "dashed")
  #let dim-label(body) = text(size: 6.5pt, fill: mid)[#body]
  // Наконечники стрелок
  // Размер 3pt учитывается в h-dim/v-dim
  #let h-head-left = box(width: 3pt, height: 4pt)[#polygon(fill: mid, (0pt, 2pt), (3pt, 0pt), (3pt, 4pt))]
  #let h-head-right = box(width: 3pt, height: 4pt)[#polygon(fill: mid, (3pt, 2pt), (0pt, 0pt), (0pt, 4pt))]
  #let v-head-top = box(width: 4pt, height: 3pt)[#polygon(fill: mid, (2pt, 0pt), (0pt, 3pt), (4pt, 3pt))]
  #let v-head-bottom = box(width: 4pt, height: 3pt)[#polygon(fill: mid, (2pt, 3pt), (0pt, 0pt), (4pt, 0pt))]
  // Горизонтальная и вертикальная размерные стрелки
  #let h-dim(len) = box(width: len, height: 0pt)[
    #place(left + horizon, dx: 0cm)[#line(length: len, stroke: dim-stroke)]
    #place(left + horizon, dx: 0cm)[#h-head-left]
    #place(left + horizon, dx: len - 3pt)[#h-head-right]
  ]
  #let v-dim(len) = box(width: 0pt, height: len)[
    #place(center + top, dy: 0cm)[#line(length: len, angle: 90deg, stroke: dim-stroke)]
    #place(center + top, dy: 0cm)[#v-head-top]
    #place(center + top, dy: len - 3pt)[#v-head-bottom]
  ]
  #align(center)[
    #box(width: 9.2cm, height: 12.8cm, stroke: 0.8pt + dark)[
      #place(top + right, dx: -0.44cm, dy: 0.43cm)[#text(size: 8pt)[3]]
      // Верхнее и нижнее поля: 2 см
      #place(top + left, dx: 4.6cm, dy: 0cm)[#v-dim(0.86cm)]
      #place(top + left, dx: 4.43cm, dy: 1.12cm)[#dim-label[2 см]]
      #place(top + left, dx: 4.6cm, dy: 11.94cm)[#v-dim(0.86cm)]
      #place(bottom + left, dx: 4.43cm, dy: -1.12cm)[#dim-label[2 см]]
      // Левое и правое поля: 3 см и 1 см
      #place(top + left, dx: 0cm, dy: 6.4cm)[#h-dim(1.32cm)]
      #place(top + left, dx: 1.55cm, dy: 6.31cm)[#dim-label[3 см]]
      #place(top + left, dx: 8.76cm, dy: 6.4cm)[#h-dim(0.44cm)]
      #place(top + left, dx: 8.1cm, dy: 6.31cm)[#dim-label[1 см]]
      // Пунктирная рамка - область текста
      #place(top + left, dx: 1.32cm, dy: 0.86cm)[
        #rect(width: 7.44cm, height: 11.08cm, stroke: (paint: brd-dk, thickness: 0.5pt, dash: "dashed"))[
          #set align(center + horizon)
          #text(size: 8pt, fill: mid)[область текста]
        ]
      ]
    ]
  ]
  #v(0.3em)
]

// ─────────────────────────────────────────────────────────────────────────
#S[Основной текст]

#R[
  #P[Шрифт][Times New Roman, *12 пт*, нормальный, чёрный]
  #P[Выравнивание][По ширине, автоперенос слов, допускается лёгкий перенос слов]
  #P[Абзацный отступ][*1,25 см*, в том числе у *первого* абзаца после заголовка]
  #P[Межстрочный][*Полуторный*]
  #P[Между абзацами][Интервал *0 пт* – дополнительный отступ между абзацами не добавляется]
  #P[Кавычки][Только ёлочки *«...»*. Прямые кавычки не допускаются]
  #P[Тире и дефис][Допускается только тире *«–»*. Дефис *«-»* – лишь грамматически внутри слов. Длинное тире *«—»* не используется]
  #P[Диапазоны][В диапазонах используют короткое тире *без пробелов*: 10–15, \ 2020–2024]
  #P[Единицы измерения][Между числом и единицей – *неразрывный пробел*: «10 %», «5 кг», «2025 г.». Отрывать единицу от числа (перенос на разные строки) *нельзя*]
]

#E[
  // полуторный межстрочный; между абзацами 0 пт (spacing = leading)
  #set par(leading: wlead(1.5), spacing: wlead(1.5))
  #set text(size: 11pt)

  #h(1.25cm)Первый абзац печатается с отступа 1,25 см и выравнивается по ширине. Тире отделяется пробелами – как в этом предложении; дефис пишется внутри слова: «бизнес-процесс», «IT-отдел». В официальных документах рекомендуется придерживаться единообразного оформления, чтобы текст был удобен для чтения и воспринимался как единое целое.

  #h(1.25cm)Числа и единицы измерения не разрывают: 10 %, 5 кг, 2025 г. Диапазоны оформляют коротким тире без пробелов: с. 10–15, 2020–2024 гг., пункты 1–3. Прямые кавычки `"…"` и длинное тире (—) не используются – только кавычки «ёлочки» и тире «–». При необходимости допускается выделение отдельных слов курсивом или полужирным начертанием, однако злоупотреблять такими средствами оформления не следует.

  #h(1.25cm)Информационные технологии играют важную роль в современной экономике. Автоматизация рутинных операций позволяет сократить время обработки данных, повысить качество обслуживания клиентов и снизить вероятность возникновения ошибок. Многие организации внедряют цифровые решения для оптимизации внутренних процессов.

  #h(1.25cm)При разработке программного обеспечения особое внимание уделяется архитектуре проекта, тестированию и документированию. Грамотно организованный код упрощает сопровождение системы и позволяет быстрее внедрять новые функции. Использование систем контроля версий способствует эффективной совместной работе разработчиков.
]

// ─────────────────────────────────────────────────────────────────────────
#S[Заголовки]

#R[
  #P[Первый уровень][]
  #v(0.5em)
  #P[Шрифт][Arial, *14 пт*, нормальный]
  #P[Нумерация][Арабские цифры *без точки*: 1, 2, 3…]
  #P[Выравнивание][По левому краю, с *абзацного отступа* (1,25 см), без переноса слов]
  #P[Многострочный][Продолжение – *буква под буквой*]
  #P[Интервалы][До *0 пт* (разрыв страницы), после *12 пт*, межстрочный *одинарный*]
]

#R[
  #P[Второй уровень][]
  #v(0.5em)
  #P[Шрифт][Arial, *13 пт*, нормальный]
  #P[Нумерация][*1.1*, *1.2*, *2.1*…]
  #P[Выравнивание][По левому краю, с *абзацного отступа* (1,25 см), без переноса слов]
  #P[Многострочный][Продолжение – *буква под буквой*]
  #P[Интервалы][До *12 пт*, после *6 пт*, межстрочный *одинарный*]
]

#R[
  #P[Третий уровень][]
  #v(0.5em)
  #P[Шрифт][Times New Roman, *12 пт*, полужирный]
  #P[Нумерация][*1.1.1*, *1.1.2*… Точка после последней цифры *не ставится*]
  #P[Выравнивание][По левому краю, с абзацного отступа (*1,25 см*), без переноса слов]
  #P[Интервалы][До *6 пт*, после *6 пт*, межстрочный *одинарный*]
]

#W[Между номером и текстом заголовка – *один пробел*; заголовки *не подчёркивают*; перенос слов *не допускается*; если заголовок из двух предложений, их разделяют точкой.]

#W[«Введение», «Заключение», «Содержание», «Список использованных источников», «Приложение X» – Arial *14 пт*, *по центру*, *без номера* и без абзацного отступа, каждый с *новой страницы*.]

// ── helpers для примеров заголовков ──
#let eh1(t) = {
  box(width: 1.25cm)
  text(font: "Arial", size: 14pt, hyphenate: false)[#t]
}
#let eh2(t) = {
  box(width: 1.25cm)
  text(font: "Arial", size: 13pt, hyphenate: false)[#t]
}
#let eh3(t) = {
  box(width: 1.25cm)
  text(font: "Times New Roman", size: 12pt, weight: "bold", hyphenate: false)[#t]
}
#let etx(t) = {
  box(width: 1.25cm)
  t
}
#let es-gap(size, label, dir: "down") = {
  let arrow-x = 1.37cm
  let arrow-stroke = (paint: mid, thickness: 0.5pt, dash: "dotted")
  let head-h = 3pt
  let head-down = box(width: 4pt, height: 3pt)[#polygon(fill: mid, (2pt, 3pt), (0pt, 0pt), (4pt, 0pt))]
  let head-up = box(width: 4pt, height: 3pt)[#polygon(fill: mid, (2pt, 0pt), (0pt, 3pt), (4pt, 3pt))]
  block(width: 100%, height: size, breakable: false)[
    #place(top + left, dx: arrow-x, dy: 0.05cm)[
      #box(width: 0pt, height: size)[
        #place(center + top, dy: if dir == "up" { head-h } else { 0pt })[#line(length: size - head-h, angle: 90deg, stroke: arrow-stroke)]
        #place(center + if dir == "up" { top } else { bottom }, dy: if dir == "up" { 0pt } else { -head-h })[
          #if dir == "up" { head-up } else { head-down }
        ]
        #place(left + horizon, dx: 5pt)[#box(width: 2cm)[#text(size: 6.5pt, fill: mid, hyphenate: false)[#label]]]
      ]
    ]
  ]
}
#let ecap(t) = text(style: "italic", size: 9pt, fill: mid)[#t]
