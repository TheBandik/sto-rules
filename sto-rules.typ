// СК-СТО-ТР-04-1.005-2015 – краткий справочник правил оформления

#set page(paper: "a4", margin: 2cm)
#set text(font: "Times New Roman", size: 12pt, lang: "ru", hyphenate: false)
#set par(justify: true, leading: 0.5em, spacing: 0.6em, first-line-indent: 0pt)
#show " – ": [~– ]
#show table.cell.where(y: 0): set text(hyphenate: false)  // без переноса в заголовках столбцов

// ── Палитра (монохром) ───────────────────────────────────────────────────
#let dark = rgb("#1a1a1a")
#let mid = rgb("#555555")
#let lite = rgb("#f2f2f2")
#let brd = rgb("#cccccc")
#let brd-dk = rgb("#888888")

// ── Компоненты ───────────────────────────────────────────────────────────

// Заголовок раздела
#let S(t) = {
  pagebreak(weak: true)
  text(font: "Arial", size: 14pt, weight: "bold")[#t]
  v(0.1em)
  line(length: 100%, stroke: 1pt + dark)
  v(0.3em)
}

// Блок параметров
#let R(body) = {
  block(
    width: 100%,
    stroke: (left: 2.5pt + dark, rest: 0.4pt + brd),
    inset: (left: 10pt, right: 8pt, y: 7pt),
    body,
  )
  v(0.25em)
}

// Строка параметра внутри R
#let P(param, val) = {
  grid(
    columns: (4cm, 1fr),
    column-gutter: 0.5em,
    text(weight: "bold", size: 13pt)[#param], val,
  )
  v(0.2em)
}

// Пример
#let E(body) = {
  v(0.2em)
  block(breakable: false)[
    #text(size: 11pt, style: "italic")[Пример]
    #v(0.1em)
    #block(
      width: 100%,
      stroke: 0.5pt + brd-dk,
      radius: 2pt,
      inset: (x: 12pt, y: 10pt),
      text(hyphenate: true, body), // в примерах автоперенос оставляем (правило СТО)
    )
  ]
  v(0.35em)
}

// Важно
#let W(body) = {
  block(
    width: 100%,
    stroke: (left: 2.5pt + dark, rest: 0.4pt + brd),
    inset: (left: 10pt, right: 8pt, y: 7pt),
  )[
    #text(size: 12pt, weight: "bold")[!#h(0.4em)]#body
  ]
  v(0.25em)
}

